# Docker Compose Environment Variables
# Copy this file to .env and adjust values as needed

# INSTANCE_NAME - Used to create unique container names and networks
# This allows multiple instances to run in parallel
INSTANCE_NAME=dev

# FRONTEND_PORT - External port to expose the frontend web interface
# Each instance should use a different port when running multiple instances
FRONTEND_PORT=8080

# GCP Configuration (Optional - only needed for shoppingassistantservice)
# See docker-compose.yml for usage
GCP_PROJECT_ID=your-gcp-project
GCP_REGION=us-central1
GCP_KEY_PATH=./gcp-key.json

# AlloyDB Configuration (Optional - only needed for shoppingassistantservice)
ALLOYDB_CLUSTER_NAME=microservices-cluster
ALLOYDB_INSTANCE_NAME=microservices-instance
ALLOYDB_DATABASE_NAME=microservices
ALLOYDB_TABLE_NAME=product_embeddings
ALLOYDB_SECRET_NAME=alloydb-credentials
